# Copy this file to .env and fill in your values.
# .env is gitignored - never commit real keys.

# ---------------------------------------------------------------------------
# Active provider (mirrors config/settings.py - keep in sync)
# Valid values: azure | azure_responses | openai_responses | openai_chat
# NOTE: azure_responses is not yet functional - raises NotImplementedError
# ---------------------------------------------------------------------------
PROVIDER=openai_responses

# ---------------------------------------------------------------------------
# Azure AI Foundry  (safe for Duke Health / PHI-adjacent data)
# ---------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://ai-foundry-dcri-sage.cognitiveservices.azure.com/
AZURE_OPENAI_KEY=your-azure-key-here
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_DEPLOYMENT_NAME=gpt-5.2

# ---------------------------------------------------------------------------
# OpenAI direct - Responses API  (your existing work, NOT for Duke Health data)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-key-here

# ---------------------------------------------------------------------------
# OpenAI direct - Chat Completions  (same key as above, different usage)
# No extra key needed - uses OPENAI_API_KEY
# ---------------------------------------------------------------------------
