# ===========================================================================
# .example.env — copy this to .env and fill in the values marked CHANGE_ME
# Never commit .env — it is in .gitignore
# ===========================================================================

# ---------------------------------------------------------------------------
# Azure AI Foundry — Chat Completions (PROVIDER="azure")
# ---------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://ai-foundry-dcri-sage.cognitiveservices.azure.com/
# AZURE_OPENAI_API_VERSION=2025-01-01-preview   # optional, default shown

# ---------------------------------------------------------------------------
# Azure AI Foundry — Responses API v1 (PROVIDER="azure_responses")
# ---------------------------------------------------------------------------
AZURE_OPENAI_V1_BASE_URL=https://ai-foundry-dcri-sage.openai.azure.com/openai/v1/

# ---------------------------------------------------------------------------
# Azure auth — managed identity (no API keys needed)
# Locally:  run `az login` once (persists ~90 days)
# In Azure: system-assigned managed identity on the container
# See docs/managed-identity-guide.md
# ---------------------------------------------------------------------------
# AZURE_OPENAI_KEY=CHANGE_ME  # only needed if AZURE_AUTH_MODE="api_key"

# ---------------------------------------------------------------------------
# Jira (for tools/jira_tool.py — real ticket creation)
# Get API token at: https://id.atlassian.com/manage-profile/security/api-tokens
# ---------------------------------------------------------------------------
JIRA_BASE_URL=https://dcri.atlassian.net
JIRA_EMAIL=scb2@duke.edu
JIRA_API_TOKEN=CHANGE_ME
JIRA_PROJECT_KEY=ST

# ---------------------------------------------------------------------------
# Jira Service Account (for multi-user Teams bot — Option B)
# Create a dedicated Atlassian account for the bot, grant it project access.
# See docs/design-jira-auth.md for the full trade-off discussion.
# ---------------------------------------------------------------------------
# JIRA_SERVICE_EMAIL=sagejirabot@duke.edu    # service account email
# JIRA_SERVICE_TOKEN=CHANGE_ME               # service account API token

# ---------------------------------------------------------------------------
# Atlassian OAuth 2.0 (3LO) — per-user Jira sign-in
# Register an OAuth 2.0 integration at https://developer.atlassian.com/console/myapps/
# then paste the generated Client ID and Secret below.  See bot/api/routes/auth_jira.py.
# Required scopes on the Atlassian app: read:jira-work, write:jira-work, offline_access
# ---------------------------------------------------------------------------
# ATLASSIAN_OAUTH_CLIENT_ID=CHANGE_ME
# ATLASSIAN_OAUTH_CLIENT_SECRET=CHANGE_ME
# ATLASSIAN_OAUTH_REDIRECT_URI=https://aidemo.dcri.duke.edu/sageapp06/api/v1/auth/jira/callback
# ATLASSIAN_OAUTH_POST_LOGIN_REDIRECT=/         # where to land after successful sign-in
# JIRA_PREFERRED_HOST=dcri.atlassian.net        # picked when user has multiple sites

# ---------------------------------------------------------------------------
# Session cookie signing — required when OAuth is enabled
# Any long random string; generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# If unset, a per-process ephemeral secret is used (sessions invalidate on restart).
# SESSION_COOKIE_SECURE=true sets the Secure flag — turn on when served over HTTPS.
# ---------------------------------------------------------------------------
# SESSION_SECRET=CHANGE_ME
# SESSION_COOKIE_SECURE=true

# ---------------------------------------------------------------------------
# Microsoft Graph — real email reading (tools/outlook_tool.py)
# Requires Azure AD app registration with Mail.Read — needs IT to set up
# Tenant ID is already known; Client ID + Secret come from IT after app reg
# ---------------------------------------------------------------------------
GRAPH_TENANT_ID=cb72c54e-4a31-4d9e-b14a-1ea36dfac94c
GRAPH_CLIENT_ID=CHANGE_ME
GRAPH_CLIENT_SECRET=CHANGE_ME
GRAPH_USER_EMAIL=scb2@duke.edu

# ---------------------------------------------------------------------------
# OpenAI.com — NOT for Duke Health / PHI-adjacent data
# Only for PROVIDER="openai_responses" or "openai_chat" (personal dev use)
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=CHANGE_ME  # only needed for openai_responses or openai_chat providers

# ---------------------------------------------------------------------------
# SageJiraBot Bot Framework (from IT after Azure Bot Service provisioned)
# See docs/it-request-teams-bot.md for the exact IT request to file
# ---------------------------------------------------------------------------
BOT_APP_ID=CHANGE_ME
BOT_APP_PASSWORD=CHANGE_ME
BOT_DEFAULT_PROJECT=ST
BOT_MAX_TICKETS_PER_RUN=10
BOT_SESSION_TIMEOUT_MINUTES=30
BOT_DRY_RUN_DEFAULT=false
BOT_HOST=0.0.0.0
BOT_PORT=3006

# ---------------------------------------------------------------------------
# Azure AD SSO — Web UI authentication (for bot/web/index.html)
# Register a Single-Page Application (SPA) in Azure AD, then add redirect URIs:
#   http://localhost:9000        (local dev)
#   https://<your-container>.azurecontainerapps.io  (production)
# See docs/design-jira-auth.md -> Option C for full IT instructions.
# When AZURE_AD_CLIENT_ID is not set (or is CHANGE_ME), the sign-in button is
# hidden and the app falls back to the server service account — no SSO required.
# ---------------------------------------------------------------------------
AZURE_AD_CLIENT_ID=CHANGE_ME    # App (client) ID from the Azure AD SPA app registration
AZURE_AD_TENANT_ID=cb72c54e-4a31-4d9e-b14a-1ea36dfac94c   # DCRI Duke tenant (already known)
