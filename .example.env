# ---------------------------------------------------------------------------
# Azure AI Foundry (required for PROVIDER="azure" or "azure_responses")
# ---------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://ai-foundry-dcri-sage.cognitiveservices.azure.com/
# AZURE_OPENAI_API_VERSION=2025-01-01-preview   # optional, this is the default

# ---------------------------------------------------------------------------
# Azure auth: we use managed identity (DefaultAzureCredential), not API keys.
# Locally:    run `az login` once — token persists across reboots (~90 days)
# In Azure:   enable system-assigned managed identity on your container/app
# See docs/managed-identity-guide.md for full explanation.
#
# API key auth is commented out below. Only uncomment if managed identity
# is broken and you need a quick workaround. Never commit a real key.
# ---------------------------------------------------------------------------
# AZURE_OPENAI_KEY=your-azure-key-here

# ---------------------------------------------------------------------------
# OpenAI.com (only for PROVIDER="openai_responses" or "openai_chat")
# WARNING: data leaves Duke tenant — NOT for PHI-adjacent work
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-your-openai-key-here
